# ===== ARNO K-Beauty 환경설정 =====
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env

# --- DB (compose.yml 의 arno_db 와 src/config/config.php 가 공유) ---
DB_HOST=arno_db
DB_PORT=3306
DB_NAME=accu_cosmetic
DB_USER=accu
DB_PASSWORD=__여기에_앱_계정_비번__
DB_ROOT_PASSWORD=__여기에_root_비번__

# --- 앱 ---
APP_ENV=production
APP_DEBUG=false
# 세션/보안용 임의 문자열 (아무 긴 랜덤값)
APP_KEY=__긴_랜덤_문자열로_교체__
